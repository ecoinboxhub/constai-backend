# ConstAI Backend Configuration
# Copy this to .env and fill in your values

ENV=development
DEBUG=true
API_PREFIX=/api/v1
PORT=8008
PRODUCTION_DOMAIN=

# Database
# For SQLite (local dev):
DATABASE_URL=sqlite:///./construction_ai.db
# For PostgreSQL (production):
# DATABASE_URL=postgresql+psycopg2://user:password@host:port/construction_ai

# Redis (optional, graceful fallback if not available)
REDIS_URL=redis://localhost:6379/0

# JWT
JWT_SECRET=change-me-to-a-secure-random-string
JWT_REFRESH_SECRET=change-me-to-another-secure-random-string

# AI Providers (at least one required)
GEMINI_API_KEY=
GEMINI_DEFAULT_MODEL=gemini-1.5-flash
GROQ_API_KEY=
GROQ_DEFAULT_MODEL=llama-3.3-70b-versatile
OPENROUTER_API_KEY=
OPENROUTER_DEFAULT_MODEL=google/gemini-flash-1.5
OPENAI_API_KEY=

# Weather (required for weather intelligence)
OPENWEATHER_API_KEY=

# ChromaDB vector store path
CHROMA_PERSIST_DIR=data/processed/vector_indexes

# Model registry path
MODEL_REGISTRY_PATH=artifacts/models
